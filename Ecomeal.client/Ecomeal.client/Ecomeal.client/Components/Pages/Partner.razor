@page "/partner"

<PageTitle>Become a Partner</PageTitle>

<section class="hero" style="padding: 3rem 2rem;">
    <h1>Become an EcoMeal partner 🤝</h1>
    <p>Turn surplus food into revenue and reach eco-conscious customers in your city.</p>
</section>

<div class="section">
    <div class="section-title"><h2>How to join</h2><p>Three simple steps</p></div>
    <div class="steps">
        <div class="step"><div class="num">1</div><h3>Send us an email</h3><p>Write to <strong>admin@gmail.com</strong> and tell us you'd like to join.</p></div>
        <div class="step"><div class="num">2</div><h3>Present your business</h3><p>Share your name, city, type of food and the kind of surplus you usually have.</p></div>
        <div class="step"><div class="num">3</div><h3>Get onboarded</h3><p>We review, approve and add your restaurant to the app.</p></div>
    </div>
</div>

<div class="section">
    <div class="form-card" style="max-width: 680px;">
        <h3 class="mb-3">Requirements</h3>
        <ul>
            <li>Only fresh, safe-to-eat food — no expired products.</li>
            <li>Valid business registration and food-safety authorization.</li>
            <li>Accurate pickup times and honest package descriptions.</li>
            <li>Discounted prices compared to the original menu.</li>
            <li>At least one physical location in a supported city.</li>
        </ul>
        <a class="btn btn-accent mt-2" href="mailto:admin@gmail.com">Email us at admin@gmail.com</a>
    </div>
</div>
