@page "/partner"
@rendermode InteractiveServer
@using Ecomeal.client.Services
@inject LocalizationService Loc
@implements IDisposable

<PageTitle>@Loc["partner.title"]</PageTitle>

<section class="hero" style="padding: 3rem 2rem;">
    <h1><Icon Name="handshake" /> @Loc["partner.heroTitle"]</h1>
    <p>@Loc["partner.heroText"]</p>
</section>

<div class="section">
    <div class="section-title"><h2>@Loc["partner.howToJoin"]</h2><p>@Loc["partner.threeSteps"]</p></div>
    <div class="steps">
        <div class="step"><div class="num">1</div><h3>@Loc["partner.step1Title"]</h3><p>@Loc["partner.step1Text"] <strong>admin@gmail.com</strong></p></div>
        <div class="step"><div class="num">2</div><h3>@Loc["partner.step2Title"]</h3><p>@Loc["partner.step2Text"]</p></div>
        <div class="step"><div class="num">3</div><h3>@Loc["partner.step3Title"]</h3><p>@Loc["partner.step3Text"]</p></div>
    </div>
</div>

<div class="section">
    <div class="form-card" style="max-width: 680px;">
        <h3 class="mb-3">@Loc["partner.requirements"]</h3>
        <ul>
            <li>@Loc["partner.req1"]</li>
            <li>@Loc["partner.req2"]</li>
            <li>@Loc["partner.req3"]</li>
            <li>@Loc["partner.req4"]</li>
            <li>@Loc["partner.req5"]</li>
        </ul>
        <a class="btn btn-accent mt-2" href="mailto:admin@gmail.com">@Loc["partner.emailUs"] admin@gmail.com</a>
    </div>
</div>

@code {
    protected override void OnInitialized() => Loc.OnChanged += HandleLanguageChanged;
    private void HandleLanguageChanged() => _ = InvokeAsync(StateHasChanged);
    public void Dispose() => Loc.OnChanged -= HandleLanguageChanged;
}
