@page "/orders"
@rendermode InteractiveServer
@using Ecomeal.client.Models
@using Ecomeal.client.Services
@inject OrderService OrderService

<PageTitle>My orders</PageTitle>

<div class="container">
    <h1 class="mb-4">My orders</h1>

    @if (MyOrders is null)
    {
        <p>Loading ...</p>
    }
    else if (MyOrders.Count == 0)
    {
        <p class="text-muted">You have no orders yet.</p>
    }
    else
    {
        <div class="row g-3">
            @foreach (var o in MyOrders)
            {
                <div class="col-12 col-md-6 col-lg-4" @key="o.Id">
                    <div class="card h-100">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@o.PackageName</h5>
                            <h6 class="card-subtitle">@o.BusinessName</h6>
                            <p class="card-text mb-1"><strong>Price:</strong> @o.Price</p>
                            <p class="card-text mb-1"><strong>Status:</strong> @o.Status</p>
                            <p class="card-text"><small class="text-muted">@o.Date.ToString("g")</small></p>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private List<OrderModel>? MyOrders;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            MyOrders = await OrderService.GetMyOrdersAsync();
            StateHasChanged();
        }
    }
}
