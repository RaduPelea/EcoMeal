@page "/"
@rendermode InteractiveServer
@using Ecomeal.client.Services
@inject AuthService AuthService
@inject NavigationManager Nav
@inject LocalizationService Loc
@implements IDisposable

<PageTitle>EcoMeal</PageTitle>

<section class="hero">
    <h1><Icon Name="public" /> @Loc["home.heroTitle"]</h1>
    <p>@Loc["home.heroSubtitle"]</p>
    <div class="hero-actions">
        <button class="btn btn-accent" @onclick="OrderNow">@Loc["home.orderNow"]</button>
        <a class="btn btn-outline-light" href="/order">@Loc["home.browseCategories"]</a>
    </div>
</section>

<div class="section features">
    <div class="feature"><div class="ico"><Icon Name="nutrition" /></div><h3>Fresh Deals</h3><p>Quality meals from local spots at reduced prices.</p></div>
    <div class="feature"><div class="ico"><Icon Name="savings" Class="icon-gold" /></div><h3>Save Money</h3><p>Enjoy your favorites for a fraction of the cost.</p></div>
    <div class="feature"><div class="ico"><Icon Name="recycling" Class="icon-accent" /></div><h3>Fight Waste</h3><p>Every order helps reduce food waste in your city.</p></div>
</div>

<div class="section">
    <div class="section-title"><h2>How it works</h2><p>Three simple steps</p></div>
    <div class="steps">
        <div class="step"><div class="num">1</div><h3>Pick a category</h3><p>Choose Fast Food, Bakery or Fine Dining.</p></div>
        <div class="step"><div class="num">2</div><h3>Find a deal</h3><p>Browse nearby places and their discounted packages.</p></div>
        <div class="step"><div class="num">3</div><h3>Order &amp; save</h3><p>Grab great food for less and help cut waste.</p></div>
    </div>
</div>

<div class="cta-band">
    <h2>@Loc["home.ctaTitle"]</h2>
    <p>@Loc["home.ctaText"]</p>
    <button class="btn btn-accent" @onclick="OrderNow">@Loc["home.orderNow"]</button>
</div>

@if (showLoginPrompt)
{
    <div class="eco-modal-backdrop" @onclick="ClosePrompt">
        <div class="eco-modal" @onclick:stopPropagation="true">
            <h3>Please log in first</h3>
            <p>You need an account to place an order.</p>
            <div class="actions">
                <a class="btn btn-primary" href="/login">Login</a>
                <a class="btn btn-accent" href="/register">Sign Up</a>
            </div>
            <p class="mt-3" style="font-size:0.9rem;">Don't have an account? <a href="/register">Make one now</a></p>
        </div>
    </div>
}

@code {
    protected override void OnInitialized()
    {
        Loc.OnChanged += HandleLanguageChanged;
    }

    private void HandleLanguageChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        Loc.OnChanged -= HandleLanguageChanged;
    }

    private bool showLoginPrompt;

    private void OrderNow()
    {
        if (AuthService.IsAuthenticated)
            Nav.NavigateTo("/order");
        else
            showLoginPrompt = true;
    }

    private void ClosePrompt() => showLoginPrompt = false;
}
