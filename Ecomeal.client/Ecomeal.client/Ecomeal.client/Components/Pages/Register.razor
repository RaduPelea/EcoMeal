@page "/register"
@rendermode InteractiveServer
@using EcoMeal.client.Models.Auth
@using EcoMeal.client.Services
@using Ecomeal.client.Services
@using Ecomeal.client.Components
@inject AuthService AuthService
@inject BusinessService BusinessService
@inject NavigationManager Navigation

<div class="form-card">
    <h3 class="mb-3">Create your account</h3>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">@errorMessage</div>
    }

    <EditForm Model="registerModel" OnValidSubmit="HandleRegister">
        <DataAnnotationsValidator />

        <label class="form-label">Email</label>
        <InputText class="form-control mb-1" @bind-Value="registerModel.Email" />
        <ValidationMessage For="() => registerModel.Email" />

        <label class="form-label">Password</label>
        <InputText type="password" class="form-control mb-1" @bind-Value="registerModel.Password" />
        <ValidationMessage For="() => registerModel.Password" />

        <label class="form-label">Confirm Password</label>
        <InputText type="password" class="form-control mb-1" @bind-Value="registerModel.ConfirmPassword" />
        <ValidationMessage For="() => registerModel.ConfirmPassword" />

        <label class="form-label">Name</label>
        <InputText class="form-control mb-1" @bind-Value="registerModel.Name" />
        <ValidationMessage For="() => registerModel.Name" />

        <label class="form-label">Contact Info</label>
        <InputText class="form-control mb-1" @bind-Value="registerModel.Contact" />
        <ValidationMessage For="() => registerModel.Contact" />

        <label class="form-label">City</label>
        <CitySelector Cities="cities" Value="registerModel.City" ValueChanged="OnCityChanged" />
        <ValidationMessage For="() => registerModel.City" />

        <button type="submit" class="btn btn-primary w-100 mt-3">Register</button>
    </EditForm>

    <p class="mt-3 text-center">Already have an account? <a href="/login">Login</a></p>
</div>

@code {
    private RegisterModel registerModel { get; set; } = new();
    private List<string> cities = new();
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        cities = await BusinessService.GetCitiesAsync();
    }

    private void OnCityChanged(string city) => registerModel.City = city;

    private async Task HandleRegister()
    {
        try
        {
            var result = await AuthService.RegisterAsync(
                registerModel.Email, registerModel.Password,
                registerModel.Name, registerModel.Contact, registerModel.City);

            if (result.Success)
                Navigation.NavigateTo("/login");
            else
                errorMessage = result.ErrorMessage;
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }
}
