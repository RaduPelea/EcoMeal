@page "/login"
@rendermode InteractiveServer
@using Ecomeal.client.Models.Auth
@using Ecomeal.client.Services
@inject AuthService AuthService
@inject NavigationManager Navigation
@inject LocalizationService Loc
@implements IDisposable

<PageTitle>Login</PageTitle>

<div class="form-card">
    <h3 class="mb-3">@Loc["login.title"]</h3>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
            @if (needsEmailConfirmation)
            {
                <div class="mt-2">
                    <a class="btn btn-outline-primary btn-sm" href="@($"/verify-email?email={Uri.EscapeDataString(loginModel.Email)}")">
                        @Loc["login.verifyMyEmail"]
                    </a>
                </div>
            }
        </div>
    }

    <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
        <DataAnnotationsValidator />

        <label class="form-label">@Loc["common.email"]</label>
        <InputText class="form-control mb-1" @bind-Value="loginModel.Email" />
        <ValidationMessage For="() => loginModel.Email" />

        <label class="form-label">@Loc["common.password"]</label>
        <InputText type="password" class="form-control mb-1" @bind-Value="loginModel.Password" />
        <ValidationMessage For="() => loginModel.Password" />

        <button type="submit" class="btn btn-primary w-100 mt-3">@Loc["nav.login"]</button>
    </EditForm>

    <p class="mt-3 text-center">@Loc["login.noAccount"] <a href="/register">@Loc["login.registerLink"]</a></p>
</div>

@code {
    protected override void OnInitialized() => Loc.OnChanged += HandleLanguageChanged;
    private void HandleLanguageChanged() => _ = InvokeAsync(StateHasChanged);
    public void Dispose() => Loc.OnChanged -= HandleLanguageChanged;

    private LoginModel loginModel { get; set; } = new();

    private string? errorMessage;
    private bool needsEmailConfirmation;

    private async Task HandleLogin()
    {
        try
        {
            var result = await AuthService.LoginAsync(loginModel.Email, loginModel.Password);

            if (result.Success)
            {
                Navigation.NavigateTo("/", forceLoad: true);
            }
            else
            {
                errorMessage = result.ErrorMessage;
                needsEmailConfirmation = result.NeedsEmailConfirmation;
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error: {ex.Message}";
        }
    }
}
