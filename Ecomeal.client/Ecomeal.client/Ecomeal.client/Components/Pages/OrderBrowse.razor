@page "/order/{Category}"
@rendermode InteractiveServer
@using Ecomeal.client.Models
@using Ecomeal.client.Services
@using EcoMeal.client.Services
@inject BusinessService BusinessService
@inject AuthService AuthService

<PageTitle>@Category</PageTitle>

<a class="btn btn-link px-0 mb-2" href="/order">← Back to categories</a>
<h1 class="mb-2">@Category</h1>
<p class="text-muted mb-4">
    @(string.IsNullOrEmpty(AuthService.City) ? "Showing all locations" : $"Showing places in {AuthService.City}")
</p>

@if (businesses is null)
{
    <p>Loading...</p>
}
else if (!Filtered.Any())
{
    <p class="text-muted">No places in this category @(string.IsNullOrEmpty(AuthService.City) ? "" : $"in {AuthService.City} ")yet.</p>
}
else
{
    <div class="row g-3">
        @foreach (var b in Filtered)
        {
            <div class="col-12 col-md-6 col-lg-4" @key="b.Id">
                <div class="card h-100">
                    @if (!string.IsNullOrEmpty(b.ImageUrl))
                    {
                        <img src="@b.ImageUrl" class="card-img-eco" alt="@b.Name" />
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">@b.Name</h5>
                        <h6 class="card-subtitle">@b.BusinessTypeName</h6>
                        <p class="card-text">@b.Description</p>
                        <ul class="list-unstyled small mb-3">
                            <li>📍 @b.Address, @b.City</li>
                            <li>⭐ @b.Rating</li>
                        </ul>
                        <a class="btn btn-primary mt-auto" href="@($"/business/{b.Id}")">View &amp; Order</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

@code {
    [Parameter]
    public string Category { get; set; } = "";

    private List<BusinessModel>? businesses;

    private IEnumerable<BusinessModel> Filtered =>
        (businesses ?? Enumerable.Empty<BusinessModel>())
        .Where(b => b.BusinessTypeName == Category)
        .Where(b => string.IsNullOrEmpty(AuthService.City) || b.City == AuthService.City);

    protected override async Task OnInitializedAsync()
    {
        businesses = await BusinessService.GetAllAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.LoadTokenAsync();
            StateHasChanged();
        }
    }
}
