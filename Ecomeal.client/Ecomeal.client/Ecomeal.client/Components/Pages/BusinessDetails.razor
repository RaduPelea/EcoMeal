@page "/business/{Id:int}"
@rendermode InteractiveServer
@using Ecomeal.client.Models
@using Ecomeal.client.Services
@using EcoMeal.client.Services
@inject AuthService AuthService

@if(_business is null)
{
    return;
}

<div class="container my-4">
    <a class="btn btn-link px-0 mb-2" href="/order">← Back</a>
    <div class="business-banner" style="background-image:url('@_business.ImageUrl')">
        <div class="business-banner-overlay">
            <div class="d-flex justify-content-between align-items-start">
                <h1 class="mb-2">@_business.Name</h1>
                @if (AuthService.IsAdmin)
                {
                    <a class="btn btn-light btn-sm" href="@($"/business/edit/{Id}")">Edit Business</a>
                }
            </div>
            <p class="mb-1">@_business.Description</p>
            <p class="mb-1"><strong>Type:</strong> @_business.BusinessTypeName &nbsp;·&nbsp; <strong>City:</strong> @_business.City</p>
            <p class="mb-0"><strong>Contact:</strong> @_business.Contact &nbsp;·&nbsp; <strong>Address:</strong> @_business.Address</p>
        </div>
    </div>


    <div class="d-flex justify-content-between align-items-center mt-4 mb-3">
        <h2 class="mb-0">Packages</h2>
        @if (AuthService.IsAdmin)
        {
            <button type="button" class="btn btn-primary" @onclick="NavigateToAddPackage">
                + Add Package
            </button>
        }
    </div>

    @if (_business.Packages.Count == 0)
    {
        <p class="text-muted">No packages yet.</p>
    }
    else
    {
        <div class="row g-3">
            @foreach (var pkg in _business.Packages)
            {
                <div class="col-12 col-md-6 col-lg-4" @key="pkg.Id">
                    <div class="card h-100">
                        @if (!string.IsNullOrEmpty(pkg.ImageUrl))
                        {
                            <img src="@pkg.ImageUrl" class="card-img-eco" alt="@pkg.Name" />
                        }
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title">@pkg.Name</h5>
                            <h6 class="card-subtitle">@pkg.PackageTypeName</h6>
                            <p class="card-text">@pkg.Description</p>
                            <p class="card-text mb-1"><strong>Price:</strong> @pkg.Price</p>
                            <p class="card-text"><small class="text-muted">@pkg.StartPickup.ToString("g") - @pkg.EndPickup.ToString("g")</small></p>

                            @if (AuthService.IsAdmin)
                            {
                                <div class="mt-auto d-flex gap-2">
                                    <button class="btn btn-outline-primary btn-sm flex-fill" @onclick="() => NavigateToEditPackage(pkg.Id)">Edit</button>
                                    <button class="btn btn-outline-danger btn-sm flex-fill" @onclick="() => DeletePackage(pkg.Id)">Delete</button>
                                </div>
                            }
                            else
                            {
                                <button class="btn btn-accent btn-sm mt-auto" @onclick="() => AskOrder(pkg)">Order</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (_orderPkg is not null)
{
    <div class="eco-modal-backdrop" @onclick="() => _orderPkg = null">
        <div class="eco-modal" @onclick:stopPropagation="true">
            <h3>Place this order?</h3>
            <p>Are you sure you want to order <strong>@_orderPkg.Name</strong> for @_orderPkg.Price? It will be reserved for you and removed from the list.</p>
            <div class="actions">
                <button class="btn btn-outline-secondary" @onclick="() => _orderPkg = null">Cancel</button>
                <button class="btn btn-accent" @onclick="ConfirmOrder">Yes, order it</button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int Id { get; set; }

    [Inject]
    public required BusinessService BusinessService { get; set; }
    [Inject]
    public required OrderService OrderService { get; set; }
    [Inject]
    public required NavigationManager NavigationManager { get; set; }

    private BusinessDetailsModel? _business;

    protected override async Task OnInitializedAsync()
    {
        _business = await BusinessService.GetOneById(Id);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.LoadTokenAsync();
            StateHasChanged();
        }
    }

    public void NavigateToAddPackage()
    {
        NavigationManager.NavigateTo($"/business/{Id}/addPackage");
    }

    public void NavigateToEditPackage(int packageId)
    {
        NavigationManager.NavigateTo($"/business/{Id}/editPackage/{packageId}");
    }

    private async Task DeletePackage(int packageId)
    {
        var ok = await BusinessService.DeletePackageAsync(packageId);
        if (ok)
            _business?.Packages.RemoveAll(p => p.Id == packageId);
    }

    private PackageModel? _orderPkg;

    private void AskOrder(PackageModel pkg) => _orderPkg = pkg;

    private async Task ConfirmOrder()
    {
        if (_orderPkg is null) return;

        var id = _orderPkg.Id;
        _orderPkg = null;

        var ok = await OrderService.PlaceOrderAsync(id);
        if (ok)
            _business?.Packages.RemoveAll(p => p.Id == id);
    }
}
