@page "/change-city"
@rendermode InteractiveServer
@using Ecomeal.client.Services
@using Ecomeal.client.Components
@inject AuthService AuthService
@inject BusinessService BusinessService
@inject IJSRuntime JS
@inject LocalizationService Loc
@implements IDisposable

<div class="form-card">
    <h3 class="mb-3">@Loc["city.title"]</h3>

    @if (!string.IsNullOrEmpty(message))
    {
        <div class="alert @(isError ? "alert-danger" : "alert-success")">@message</div>
    }

    <p class="text-muted">@Loc["city.current"]: <strong>@(string.IsNullOrEmpty(AuthService.City) ? Loc["city.notSet"] : AuthService.City)</strong></p>

    <label class="form-label">@Loc["city.new"]</label>
    <CitySelector Cities="cities" Value="selectedCity" ValueChanged="c => selectedCity = c" />

    <button class="btn btn-primary w-100 mt-3" @onclick="Save" disabled="@string.IsNullOrEmpty(selectedCity)">@Loc["common.save"]</button>
    <button class="btn btn-link w-100 mt-2" @onclick="GoBack">@Loc["common.back"]</button>
</div>

@code {
    protected override void OnInitialized() => Loc.OnChanged += HandleLanguageChanged;
    private void HandleLanguageChanged() => _ = InvokeAsync(StateHasChanged);
    public void Dispose() => Loc.OnChanged -= HandleLanguageChanged;

    private async Task GoBack()
    {
        await JS.InvokeVoidAsync("history.back");
    }

    private List<string> cities = new();
    private string selectedCity = "";
    private string? message;
    private bool isError;

    protected override async Task OnInitializedAsync()
    {
        cities = await BusinessService.GetCitiesAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.LoadTokenAsync();
            StateHasChanged();
        }
    }

    private async Task Save()
    {
        var (success, error) = await AuthService.UpdateCityAsync(selectedCity);
        isError = !success;
        message = success ? string.Format(Loc["city.changed"], selectedCity) : (error ?? Loc["city.failed"]);
    }
}
