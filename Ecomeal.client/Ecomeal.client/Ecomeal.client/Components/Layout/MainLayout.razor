@inherits LayoutComponentBase
@using EcoMeal.client.Services
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="page">
    <nav class="eco-navbar">
        <a class="eco-brand" href="/">🌿 EcoMeal</a>
        <div class="eco-nav-links">
            <a href="/">Home</a>
            <a href="/order">Order</a>
            @if (AuthService.IsAdmin)
            {
                <a href="/manage">Manage</a>
            }
        </div>
        <div class="eco-nav-actions">
            @if (AuthService.IsAuthenticated)
            {
                <a class="btn btn-outline-light btn-sm" href="/orders">My Orders</a>
                <span class="eco-city">📍 @(string.IsNullOrEmpty(AuthService.City) ? "No city" : AuthService.City)</span>
                <a class="btn btn-outline-light btn-sm" href="/change-city">Change city</a>
                <button class="btn btn-outline-light btn-sm" @onclick="() => showLogoutConfirm = true">Logout</button>
            }
            else
            {
                <a class="btn btn-light btn-sm" href="/login">Login</a>
                <a class="btn btn-accent btn-sm" href="/register">Sign Up</a>
            }
        </div>
    </nav>

    <main>
        <article class="content">
            @Body
        </article>
    </main>

    <footer class="eco-footer">
        <div class="inner">
            <span class="brand">🌿 EcoMeal</span>
            <span>Own a restaurant? <a href="/partner">Want to become a partner? →</a></span>
            <span>
                <a href="/">Home</a>
                <a href="/order">Order</a>
                <a href="/partner">Partner</a>
            </span>
        </div>
    </footer>
</div>

@if (showLogoutConfirm)
{
    <div class="eco-modal-backdrop" @onclick="() => showLogoutConfirm = false">
        <div class="eco-modal" @onclick:stopPropagation="true">
            <h3>Log out?</h3>
            <p>Are you sure you want to log out of your account?</p>
            <div class="actions">
                <button class="btn btn-outline-secondary" @onclick="() => showLogoutConfirm = false">Cancel</button>
                <button class="btn btn-danger" @onclick="HandleLogout">Log out</button>
            </div>
        </div>
    </div>
}

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await AuthService.LoadTokenAsync();
            StateHasChanged();
        }
    }

    private bool showLogoutConfirm;

    private async Task HandleLogout()
    {
        showLogoutConfirm = false;
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/", forceLoad: true);
    }
}
