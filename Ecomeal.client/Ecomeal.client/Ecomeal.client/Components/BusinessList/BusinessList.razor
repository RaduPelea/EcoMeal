@namespace Ecomeal.client.Components.BusinessList
@using Ecomeal.client.Components.BusinessCard
@using Ecomeal.client.Models
@using Ecomeal.client.Services
@inject Ecomeal.client.Services.LocalizationService Loc
@inject BusinessService BusinessService


@if (businesses is null)
{
    <div class="loading-state"><div class="spinner-border text-success" role="status"></div></div>
}
else if (businesses.Count == 0)
{
    <div class="empty-state">
        <Icon Name="storefront" Class="ico" />
        <p>@Loc["manage.noBusinesses"]</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var business in businesses)
        {
            <div class="col-12 col-sm-6 col-md-4 col-lg-3" @key="business.Id">
                <BusinessCard Business="business" OnDeleted="RemoveBusiness" />
            </div>
        }
    </div>
}

@code {
    private List<BusinessModel>? businesses;
    
    protected override async Task OnInitializedAsync()
    {
        businesses = await BusinessService.GetAllAsync();
    }

    // Apelat după ștergere: scoate afacerea din listă.
    private void RemoveBusiness(int id)
    {
        businesses?.RemoveAll(b => b.Id == id);
    }
}
