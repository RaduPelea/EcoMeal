@namespace Ecomeal.client.Components.BusinessCard
@using Ecomeal.client.Models
@using Ecomeal.client.Services
@inject Ecomeal.client.Services.LocalizationService Loc
@inject BusinessService BusinessService
@inject NavigationManager Navigation
@inject ToastService ToastService



<div class="card h-100 shadow-sm">
    <div class="card-body d-flex flex-column">
        <h5 class="card-title">@Business.Name</h5>
        <h6 class="card-subtitle mb-2 text-muted">@Business.BusinessTypeName</h6>
        <p class="card-text">@Business.Description</p>

        <p class="mb-1"><Stars Value="@Business.Rating" /></p>
        <ul class="list-unstyled small mb-3">
            <li><Icon Name="location_on" Class="icon-sm" /> @Business.Address</li>
            <li><Icon Name="mail" Class="icon-sm" /> @Business.Contact</li>
        </ul>

        <div class="mt-auto d-flex gap-2">
            <button class="btn btn-outline-primary flex-fill" @onclick="NavigateToDetails">
                @Loc["card.details"]
            </button>
            <button class="btn btn-danger flex-fill"
                    @onclick="DeleteAsync"
                    disabled="@_isDeleting">
                @(_isDeleting ? Loc["card.deleting"] : Loc["common.delete"])
            </button>
        </div>
    </div>
</div>

@code {
    // date afacere <= businesslist
    [Parameter]
    public required BusinessModel Business { get; set; }

    // signal businesslist =>deleted the business
    [Parameter]
    public EventCallback<int> OnDeleted { get; set; }

    //  block button while deleting
    private bool _isDeleting;

    private async Task DeleteAsync()
    {
        _isDeleting = true;
        var (success, error) = await BusinessService.DeleteAsync(Business.Id);
        _isDeleting = false;

        if (success)
        {
            // call la lista ca afacerea a fost stearsa
            await OnDeleted.InvokeAsync(Business.Id);
            ToastService.ShowSuccess(Loc["card.deleted"]);
        }
        else
        {
            ToastService.ShowError(error ?? Loc["card.deleteFailed"]);
        }
    }
    // Navigheaza la pagina de detalii (/business/{id})
    private void NavigateToDetails()
    {
        Navigation.NavigateTo($"/business/{Business.Id}");
    }
}

